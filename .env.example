# Copy this file to ".env" and set ONE provider for synthesized answers.
# Leave as-is to run in deterministic "mock" mode (retrieval only, no API key).

# Choose: anthropic | openai | mock
LLM_PROVIDER=mock

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: point at a different docs folder
# KB_DOCS_DIR=docs
